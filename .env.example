# Copy to .env and adjust. PostgreSQL URL for local Docker:
DATABASE_URL="postgresql://finance:finance@localhost:5432/finance_dashboard?schema=public"

JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="8h"

PORT=3000

# Optional: public base URL for /docs "Try it" (e.g. https://your-app.up.railway.app)
# PUBLIC_API_URL=https://your-app.up.railway.app
